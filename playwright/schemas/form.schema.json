{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/extracted-form.schema.json",
  "title": "ExtractedFormResult",
  "oneOf": [
    {
      "type": "object",
      "required": [
        "status",
        "url",
        "ats",
        "page_title",
        "current_step",
        "form_ready",
        "submit_visible",
        "submit_enabled",
        "fields",
        "warnings",
        "extracted_at"
      ],
      "properties": {
        "status": { "const": "success" },
        "url": { "type": "string", "format": "uri" },
        "ats": { "enum": ["greenhouse", "workday", "unknown"] },
        "page_title": { "type": "string" },
        "current_step": { "type": ["string", "null"] },
        "form_ready": { "type": "boolean" },
        "submit_visible": { "type": "boolean" },
        "submit_enabled": { "type": "boolean" },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "field_id",
              "label",
              "type",
              "required",
              "options",
              "placeholder",
              "help_text",
              "section",
              "current_value",
              "selector_hint",
              "visible",
              "enabled",
              "validation_text",
              "semantic_category",
              "group_id",
              "group_label",
              "group_type",
              "options_deferred",
              "file_kind",
              "sensitivity",
              "auto_answer_safe",
              "internal",
              "source_tag",
              "name_attr",
              "id_attr",
              "aria_label"
            ],
            "properties": {
              "field_id": { "type": "string" },
              "label": { "type": "string" },
              "type": {
                "enum": [
                  "text",
                  "email",
                  "tel",
                  "textarea",
                  "checkbox",
                  "radio",
                  "select",
                  "combobox",
                  "file",
                  "unknown"
                ]
              },
              "required": { "type": "boolean" },
              "options": {
                "type": "array",
                "items": { "type": "string" }
              },
              "placeholder": { "type": ["string", "null"] },
              "help_text": { "type": ["string", "null"] },
              "section": { "type": ["string", "null"] },
              "current_value": {
                "oneOf": [
                  { "type": "string" },
                  { "type": "boolean" },
                  {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  { "type": "null" }
                ]
              },
              "selector_hint": { "type": ["string", "null"] },
              "visible": { "type": "boolean" },
              "enabled": { "type": "boolean" },
              "validation_text": { "type": ["string", "null"] },
              "semantic_category": {
                "enum": [
                  "personal_identity",
                  "contact_info",
                  "profile_link",
                  "work_authorization",
                  "employment_history",
                  "compensation",
                  "attachment",
                  "demographic",
                  "unknown"
                ]
              },
              "group_id": { "type": ["string", "null"] },
              "group_label": { "type": ["string", "null"] },
              "group_type": { "enum": ["none", "single_choice", "multi_choice"] },
              "options_deferred": { "type": "boolean" },
              "file_kind": { "enum": ["resume", "cover_letter", "other", "unknown"] },
              "sensitivity": { "enum": ["none", "demographic", "legal", "compensation"] },
              "auto_answer_safe": { "type": "boolean" },
              "internal": { "type": "boolean" },
              "source_tag": { "type": ["string", "null"] },
              "name_attr": { "type": ["string", "null"] },
              "id_attr": { "type": ["string", "null"] },
              "aria_label": { "type": ["string", "null"] }
            },
            "additionalProperties": false
          }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        },
        "extracted_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": [
        "status",
        "reason",
        "current_url",
        "ats_guess",
        "screenshot_path",
        "trace_path",
        "extracted_at"
      ],
      "properties": {
        "status": { "enum": ["blocked", "error"] },
        "reason": { "type": "string" },
        "current_url": { "type": "string", "format": "uri" },
        "ats_guess": { "enum": ["greenhouse", "workday", "unknown"] },
        "screenshot_path": { "type": ["string", "null"] },
        "trace_path": { "type": ["string", "null"] },
        "extracted_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  ]
}
