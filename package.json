{
  "name": "auto-apply-scraper",
  "version": "0.1.0",
  "private": true,
  "description": "Deterministic Playwright-based scraper for ATS application forms",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "setup:device": "bash scripts/bootstrap-device.sh",
    "doctor": "bash scripts/doctor.sh",
    "deploy:device": "bash scripts/deploy-on-device.sh",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "playwright test",
    "example:scrape": "tsx examples/scrape-page.ts",
    "example:scrape:linkedin": "tsx examples/scrape-linkedin-easy-apply.ts",
    "example:answer-plan": "tsx examples/run-answer-plan.ts",
    "example:executor": "tsx examples/run-executor.ts",
    "tool:scrape": "tsx tools/scrape-cli.ts",
    "tool:answer-plan": "tsx tools/answer-plan-cli.ts",
    "tool:execute": "tsx tools/execute-cli.ts",
    "tool:job-pool": "tsx tools/job-pool-cli.ts",
    "tool:ledger": "tsx tools/ledger-cli.ts",
    "tool:skill": "tsx tools/skill-cli.ts",
    "tool:pipeline": "tsx tools/pipeline-cli.ts",
    "tool:run": "tsx tools/run-cli.ts"
  },
  "dependencies": {
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.14.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
