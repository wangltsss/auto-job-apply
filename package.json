{
  "name": "auto-apply-scraper",
  "version": "0.1.0",
  "private": true,
  "description": "Deterministic Playwright-based scraper for ATS application forms",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
