{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noEmitOnError": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": [
    "playwright/**/*.ts",
    "reasoning/**/*.ts",
    "executor/**/*.ts",
    "orchestration/**/*.ts",
    "tools/**/*.ts",
    "examples/**/*.ts",
    "tests/**/*.ts"
  ]
}
